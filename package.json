  "scripts": {
    "build": "./build.sh",
    "build:config": "vite build --config src/ts/config/vite.config.ts",
    "dev:config": "vite --config src/ts/config/vite.config.ts",
    "aplite": "./build.sh && pebble install --emulator aplite && pebble logs --emulator aplite",
