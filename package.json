    "chalk": "./build.sh && pebble install --emulator chalk && pebble logs --emulator chalk",
    "phone": "./build.sh && pebble install --phone 10.0.0.227 && pebble logs --phone 10.0.0.227",
    "update-leagues": "node scripts/fetch-slugs.mjs && node scripts/fetch-leagues.mjs"
  },
